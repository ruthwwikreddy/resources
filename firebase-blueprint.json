{
  "entities": {
    "Resource": {
      "title": "Resource",
      "description": "An AI or coding-related resource.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "externalLink": { "type": "string" },
        "promptBlocks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "code": { "type": "string" }
            }
          }
        },
        "upvotes": { "type": "number" },
        "bookmarks": { "type": "number" },
        "copyCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "description", "category", "difficulty", "content"]
    },
    "Category": {
      "title": "Category",
      "description": "A category for resources.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "icon"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "bookmarkedResources": { "type": "array", "items": { "type": "string" } },
        "upvotedResources": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Collection of resources."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of categories."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
